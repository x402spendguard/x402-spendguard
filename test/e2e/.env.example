# x402-spendguard end-to-end harness — environment template.
#
# The DENY-PATH suite (deny-path.e2e.test.ts) needs NONE of these: it never releases a
# signature, so it runs fully hermetic (localhost, no key, no funds). `npm run test:e2e` works
# with no .env at all.
#
# These are for the DEFERRED funded settle path (one real allowed micro-payment on a testnet).
# Copy this file to `.env` (which is gitignored) and fill in TESTNET values only. NEVER put a
# mainnet key or any funded-with-real-value key here.

# A base-sepolia (testnet) private key holding only faucet USDC. Testnet value only.
TESTNET_PRIVATE_KEY=

# The x402 facilitator to settle against (testnet). Leave blank to skip the settle path.
X402_FACILITATOR_URL=

# An x402-protected testnet resource that returns a 402 (optional; the harness can also serve
# its own local 402). Leave blank to use the built-in local resource server.
X402_RESOURCE_URL=
