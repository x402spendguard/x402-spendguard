# x402-spendguard — FUNDED settle e2e environment.
#
# The DENY-path suite (deny-path.e2e.test.ts) needs NONE of this and stays hermetic. These vars
# drive the FUNDED settle test (funded-settle.e2e.test.ts), which moves REAL testnet value.
#
# To run it: copy this file to `test/e2e/.env` (gitignored — a real key never enters the repo)
# and fill in TESTNET_PRIVATE_KEY. Then: `npm run test:e2e:funded`. Without a key, the funded
# test self-skips. See FUNDED.md for the full runbook.

# REQUIRED. A THROWAWAY base-sepolia private key (0x-prefixed, 64 hex). Fund it with faucet USDC
# ONLY — no ETH is needed: EIP-3009 is relayed and the facilitator sponsors gas. Get testnet USDC
# at https://faucet.circle.com (select "Base Sepolia"). Never use a mainnet or funded-with-value key.
TESTNET_PRIVATE_KEY=

# OPTIONAL. Recipient of the micro-payment. Defaults to a freshly generated throwaway address
# (the USDC simply moves off the payer — fine for a settlement proof).
X402_PAY_TO=

# OPTIONAL. Amount in ATOMIC USDC units (USDC has 6 decimals). Default 10000 = 0.01 USDC.
X402_AMOUNT=

# OPTIONAL. Facilitator URL. Leave blank to use the SDK default (the x402.org testnet facilitator,
# which verifies + settles and sponsors gas).
X402_FACILITATOR_URL=
